rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /learning_articles/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /crops_pests/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /crops/{cropId} {
      allow read: if true;
      allow write: if isAdmin();

      match /cultivation_stages/{stageId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
