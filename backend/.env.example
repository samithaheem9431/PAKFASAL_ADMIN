PORT=4000
# Recommended: absolute or relative path to service account JSON (relative paths resolve from backend/)
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccount.json

# Legacy fallback: JSON string or path to JSON
# FIREBASE_SERVICE_ACCOUNT_KEY=

# Must match your Firebase Storage bucket name (Admin SDK optional if rules use default)
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Comma-separated origins for CORS (optional)
# CORS_ORIGIN=http://localhost:5173